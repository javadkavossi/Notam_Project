# نمونهٔ متغیرهای محیطی — این فایل را به .env کپی کنید و مقادیر واقعی را بگذارید.
#   cp .env.example .env
# فایل .env هرگز کامیت نمی‌شود (در .gitignore است).

# ---- محیط ----
APP_ENV=docker

# ---- منبع NOTAM (FAA SWIM / Solace) ----
# مقادیر حساس؛ از پنل FAA SWIM دریافت می‌شوند.
SOLACE_HOST=tcps://ems2.swim.faa.gov:55443
SOLACE_VPN=AIM_FNS
SOLACE_USERNAME=__CHANGE_ME__
SOLACE_PASSWORD=__CHANGE_ME__
SOLACE_QUEUE=__CHANGE_ME__

# ---- احراز هویت موقت (تا پیاده‌سازی JWT) ----
AUTH_USER=admin
AUTH_PASS=__CHANGE_ME__

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=notam_db

# ---- pgAdmin ----
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=__CHANGE_ME__

# ---- Redis (اختیاری؛ اگر رمز دارد) ----
REDIS_PASSWORD=

# ---- JWT (برای E0-2) ----
JWT_SECRET=__CHANGE_ME__
JWT_REFRESH_SECRET=__CHANGE_ME__

# ---- Reference data (E7): مسیر فایل‌های OurAirports/GeoJSON (اختیاری) ----
REF_AIRPORTS_PATH=
REF_RUNWAYS_PATH=
REF_NAVAIDS_PATH=
REF_FIRS_PATH=
